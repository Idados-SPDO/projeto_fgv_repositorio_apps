# =============================================================================
# Template de secrets para o Repositório de Aplicações FGV IBRE.
#
# Localmente
#   - copie este arquivo para `.streamlit/secrets.toml` e preencha os valores;
#   - o `secrets.toml` está no `.gitignore` e NUNCA será versionado.
#
# Streamlit Cloud
#   - vá em App settings -> Secrets e cole o conteúdo do seu `secrets.toml`
#     (com os valores reais já preenchidos).
# =============================================================================

[snowflake]
account   = "<seu_account>"          # identificador da conta Snowflake
user      = "<seu_usuario>"
password  = "<sua_senha>"
role      = "<seu_role>"             # role com permissão no banco/schema abaixo
warehouse = "<seu_warehouse>"
database  = "BASES_SPDO"
schema    = "DB_GESTAO_DADOS_EXTERNOS_APP_REPOSITORIO"

[app]
title = "Repositório de Aplicações FGV IBRE"

[auth_api]
base_url = "http://<ip-do-lambda_auth>:8080"  # ver deploy/lambda_auth
